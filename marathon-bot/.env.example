# Strata Marathon Bot — Environment Config
# Copy to .env and fill in your values

# ─── Contract Addresses ──────────────────────────────────────
# Your deployed Strata package ID (from Published.toml or sui client publish output)
STRATA_PACKAGE_ID=0x...

# DeepBook Predict package ID (for market_key::new and PositionMinted/Redeemed events)
PREDICT_PACKAGE_ID=0x...

# Vault<DUSDC> shared object ID. Note: all Strata strategy pages (PLP+Hedge,
# Range Ladder) share this single vault — there is no separate vault per strategy.
VAULT_ID=0x...

# ShareTreasury shared object ID (required arg for vault::deposit/withdraw)
SHARE_TREASURY_ID=0x...

# PredictManager shared object owned by the operator and linked to the vault
PREDICT_MANAGER_ID=0x...

# Predict's top-level shared protocol object
PREDICT_ID=0x...

# StrategyConfig shared object (hedge_ratio_bps / hedge_strike_offset_bps)
STRATEGY_CONFIG_ID=0x...

# Full coin type string for dUSDC, e.g.:
# 0xabcd1234::dusdc::DUSDC
DUSDC_COIN_TYPE=0x...::dusdc::DUSDC

# ─── Operator Key ────────────────────────────────────────────
# Bech32 secret key string as exported by `sui keytool export --key-identity <alias>`
# (the "suiprivkey1..." string). Passed directly to Ed25519Keypair.fromSecretKey().
OPERATOR_PRIVATE_KEY=

# ─── Predict Server ──────────────────────────────────────────
PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com
