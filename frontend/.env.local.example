# Strata Frontend — Environment Config
# Copy to .env.local and fill in your values

# OpenAI API key, used by /api/create-vault/chat for the AI vault strategy advisor.
# If unset, that route falls back to a mock strategy (useful for local UI testing).
OPENAI_API_KEY=

# Operator's Sui private key (bech32 "suiprivkey1..." string), used by
# /api/create-vault/deploy to call strata::vault_factory::register_vault on-chain.
OPERATOR_PRIVATE_KEY=
